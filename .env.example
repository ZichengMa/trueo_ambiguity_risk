# DeepSeek API Configuration
# Get your API key from: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_api_key_here
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
# DeepSeek V4 supports enabled/disabled thinking mode. Disabled is faster for JSON parsing tasks.
DEEPSEEK_THINKING=disabled

# Tavily Web Search Configuration (optional, required only for use_web_search=True)
# Get your API key from: https://tavily.com/
TAVILY_API_KEY=your_tavily_api_key_here
TAVILY_SEARCH_MAX_RESULTS=5
TAVILY_SEARCH_DEPTH=basic
TAVILY_SEARCH_TOPIC=general
